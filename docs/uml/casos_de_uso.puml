@startuml casos_de_uso_moeda_estudantil
!theme plain
skinparam usecase {
  FontSize 12
  StereotypeFontSize 10
}
skinparam actor {
  FontSize 12
}
left to right direction

actor "Aluno" as A
actor "Professor" as P
actor "Empresa\nparceira" as E
actor "Sistema\ne-mail" as S <<sistema>>

package "Sistema de Moeda Estudantil" {
  usecase "US01: Cadastrar (dados e instituição)" as UC1
  usecase "US02: Consultar saldo do professor" as UC2
  usecase "US03: Enviar moedas com justificativa" as UC3
  usecase "US04: Consultar extrato" as UC4
  usecase "US05: Gerenciar vantagens" as UC5
  usecase "US06: Resgatar vantagem" as UC6
  usecase "US07: Enviar e-mails de notificação" as UC7
}

A - UC1
A - UC4
A - UC6
P - UC2
P - UC3
P - UC4
E - UC5
UC3 ..> UC7 : <<include>>\n(notificar aluno)
UC6 ..> UC7 : <<include>>\n(cupom / notificação)

S - UC7

note right of UC2
  Crédito 1000 moedas
  / semestre (regra
  de negócio)
end note

@enduml
